# Telegram API credentials from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token from @BotFather (for sending "new plate" notifications)
BOT_TOKEN=123456:ABC-DEF...

# Chat ID where the bot sends notifications (user or group)
# Get it e.g. by messaging @userinfobot or starting the bot and checking getUpdates
NOTIFICATION_CHAT_ID=123456789

# Comma-separated list of channels/groups to monitor (usernames or numeric IDs)
# CHANNELS=channel1,channel2,-1001234567890

# Optional: Google Sheets (path to service account JSON, spreadsheet ID, sheet tab name)
# GOOGLE_CREDENTIALS_PATH=google_credentials.json
# GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_from_url
# GOOGLE_SHEET_NAME=Номера
